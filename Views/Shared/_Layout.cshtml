<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-tertiary": "#ffffff",
                    "surface-container-lowest": "#ffffff",
                    "on-secondary": "#ffffff",
                    "on-primary-fixed-variant": "#514444",
                    "on-surface-variant": "#4e4444",
                    "tertiary-container": "#412e18",
                    "on-surface": "#1c1c18",
                    "secondary-container": "#f8dac2",
                    "inverse-on-surface": "#f3f0e9",
                    "surface-container": "#f1eee7",
                    "outline": "#807474",
                    "on-tertiary-fixed-variant": "#58432b",
                    "surface-tint": "#695b5b",
                    "on-tertiary-container": "#b19578",
                    "surface-dim": "#dcdad3",
                    "secondary-fixed": "#fbddc5",
                    "on-primary-container": "#a79696",
                    "tertiary-fixed": "#fdddbc",
                    "surface-variant": "#e5e2db",
                    "background": "#fcf9f2",
                    "surface-container-low": "#f6f3ec",
                    "on-secondary-fixed-variant": "#574331",
                    "surface": "#fcf9f2",
                    "secondary": "#705a47",
                    "on-primary": "#ffffff",
                    "tertiary": "#2a1906",
                    "on-secondary-fixed": "#271809",
                    "on-primary-fixed": "#231919",
                    "on-tertiary-fixed": "#281805",
                    "primary-fixed-dim": "#d5c2c2",
                    "on-error": "#ffffff",
                    "surface-container-highest": "#e5e2db",
                    "surface-bright": "#fcf9f2",
                    "on-background": "#1c1c18",
                    "inverse-primary": "#d5c2c2",
                    "secondary-fixed-dim": "#dec1aa",
                    "tertiary-fixed-dim": "#e0c1a2",
                    "outline-variant": "#d1c3c3",
                    "error-container": "#ffdad6",
                    "inverse-surface": "#31312c",
                    "error": "#ba1a1a",
                    "on-secondary-container": "#745e4b",
                    "primary": "#251a1a",
                    "primary-fixed": "#f2dedd",
                    "surface-container-high": "#ebe8e1",
                    "primary-container": "#3b2f2f",
                    "on-error-container": "#93000a"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "spacing": {
                    "unit": "8px",
                    "margin": "32px",
                    "gutter": "24px",
                    "section-gap": "64px",
                    "container-max": "1280px"
            },
            "fontFamily": {
                    "h3": ["Inter"],
                    "h2": ["Inter"],
                    "body-lg": ["Inter"],
                    "label-caps": ["Inter"],
                    "body-md": ["Inter"],
                    "h1": ["Inter"]
            },
            "fontSize": {
                    "h3": ["24px", {"lineHeight": "1.4", "letterSpacing": "0", "fontWeight": "600"}],
                    "h2": ["36px", {"lineHeight": "1.3", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                    "body-lg": ["18px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                    "label-caps": ["12px", {"lineHeight": "1.0", "letterSpacing": "0.05em", "fontWeight": "600"}],
                    "body-md": ["16px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                    "h1": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}]
            }
          },
        },
      }
    </script>

    <style>
        body { background-color: #fcf9f2; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .book-card-shadow {
            box-shadow: 0 10px 30px -5px rgba(59, 47, 47, 0.1);
        }
        .book-card-shadow:hover {
            box-shadow: 0 20px 40px -10px rgba(59, 47, 47, 0.15);
        }
    </style>
</head>

<body>
    <header class="bg-[#3B2F2F] dark:bg-[#1A1616] text-white dark:text-stone-100 font-['Inter'] antialiased tracking-tight docked full-width top-0 sticky z-50 border-b border-stone-700 dark:border-stone-800 shadow-lg shadow-[#3B2F2F]/10">
        <nav class="flex justify-around items-center px-8 h-20 w-full">
            <span class="text-2xl font-bold tracking-tighter text-white uppercase">NexoLibro</span>
            <div class="hidden md:flex gap-8 items-center">
                <a class="text-stone-300 font-medium hover:text-white transition-all hover:bg-white/5 rounded-md px-3 py-2 transition-colors" asp-action="Index" asp-controller="Home">Home</a>
                <a class="text-stone-300 font-medium hover:text-white transition-all hover:bg-white/5 rounded-md px-3 py-2 transition-colors" asp-action="Index" asp-controller="Users">Users</a>
                <a class="text-stone-300 font-medium hover:text-white transition-all hover:bg-white/5 rounded-md px-3 py-2 transition-colors" asp-action="Index" asp-controller="Books">Books</a>
                <a class="text-stone-300 font-medium hover:text-white transition-all hover:bg-white/5 rounded-md px-3 py-2 transition-colors" asp-action="Index" asp-controller="Loans">Loans</a>
            </div>
        </nav>
    </header>

    <!-- MAIN -->
    <div class="container-fluid">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-stone-50 dark:bg-stone-950 text-[#3B2F2F] dark:text-stone-300 font-['Inter'] text-sm tracking-wide uppercase font-medium full-width border-t border-stone-200 dark:border-stone-800 tonal-shift-bg flat no shadows transition-all duration-300">
        <div class="flex flex-col md:flex-row justify-between items-center py-16 px-12 max-w-7xl mx-auto w-full">
            <div class="mb-12 md:mb-0">
                <span class="text-lg font-black text-[#3B2F2F] dark:text-white block mb-4">NexoLibro</span>
                <p class="normal-case font-normal text-stone-500 max-w-xs">
                    © 2026 NexoLibro. Read without limits. Your digital portal to the universal knowledge.
                </p>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-2 gap-x-16 gap-y-8 text-center md:text-left">
                <div class="space-y-4">
                    <a class="block text-stone-500 hover:text-[#3B2F2F] hover:underline decoration-[#6BAA75] decoration-2 underline-offset-4" href="#">Privacy Policy</a>
                    <a class="block text-stone-500 hover:text-[#3B2F2F] hover:underline decoration-[#6BAA75] decoration-2 underline-offset-4" href="#">Terms of Service</a>
                </div>
                <div class="space-y-4">
                    <a class="block text-stone-500 hover:text-[#3B2F2F] hover:underline decoration-[#6BAA75] decoration-2 underline-offset-4" href="#">Library Rules</a>
                    <a class="block text-stone-500 hover:text-[#3B2F2F] hover:underline decoration-[#6BAA75] decoration-2 underline-offset-4" href="#">Contact Support</a>
                </div>
            </div>
            <div class="mt-12 md:mt-0 flex gap-6">
                <a class="material-symbols-outlined text-stone-400 hover:text-[#6BAA75] transition-colors" href="#">language</a>
                <a class="material-symbols-outlined text-stone-400 hover:text-[#6BAA75] transition-colors" href="#">share</a>
                <a class="material-symbols-outlined text-stone-400 hover:text-[#6BAA75] transition-colors" href="#">mail</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>