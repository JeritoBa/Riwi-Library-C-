@{
    ViewData["Title"] = "NexoLibro | Users Management";
}
@model Exercise4.ViewModels.UserViewModel;

<section class="max-w-7xl mx-auto px-8 py-section-gap">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div class="space-y-2">
            <h1 class="font-h1 text-h1 text-primary">User Management</h1>
            <p class="text-body-lg text-secondary max-w-2xl">Manage your digital sanctuary's community. Monitor memberships, update roles, and welcome new readers.</p>
        </div>
    </div>
    <!-- Showing Errors -->
    <div asp-validation-summary="All" class="text-red-700 px-4 py-3 rounded"></div>
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
            @TempData["ErrorMsg"]
        </div>
    }
    
    <!-- New User Registration Section -->
    <div class="bg-white rounded-xl shadow-sm border border-outline-variant p-8 mb-12">
        <div class="mb-6">
            <h2 class="text-xl font-bold text-primary mb-1">New User Registration</h2>
            <p class="text-sm text-secondary">Register a new member to the NexoLibro community.</p>
        </div>
        <form asp-action="Create" asp-controller="Users" method="post" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-end">
            <div class="space-y-2"> <!-- NAME -->
                <span class="text-danger d-block" asp-validation-for="NewUser.Name"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.Name">First Name</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.Name" placeholder="e.g. Mateo" type="text"/>
            </div>
            <div class="space-y-2"> <!-- LAST NAME -->
                <span class="text-danger d-block" asp-validation-for="NewUser.LastName"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.LastName">Last Name</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.LastName" placeholder="e.g. Silva" type="text"/>
            </div>
            <div class="space-y-2"> <!-- EMAIL -->
                <span class="text-danger d-block" asp-validation-for="NewUser.Email"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.Email">Email Address</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.Email" placeholder="m.silva@example.com" type="email"/>
            </div>
            <div class="space-y-2"> <!-- PHONE -->
                <span class="text-danger d-block" asp-validation-for="NewUser.Phone"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.Phone">Phone Number</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.Phone" placeholder="e. g. 3123328743" type="text"/>
            </div>
            <div class="space-y-2"> <!-- ADDRESS -->
                <span class="text-danger d-block" asp-validation-for="NewUser.Address"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.Address">Address</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.Address" placeholder="e. g. Carrera 98 #23" type="text"/>
            </div>
            <div class="space-y-2"> <!-- EMERGENCY PHONE -->
                <span class="text-danger d-block" asp-validation-for="NewUser.EmergencyPhone"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewUser.EmergencyPhone">Emergency Phone</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewUser.EmergencyPhone" placeholder="e. g. 313245232" type="text"/>
            </div>
            <div class="lg:col-span-4 flex justify-end mt-2">
                <button type="submit" class="bg-[#6BAA75] text-white px-8 py-3 rounded-lg font-semibold flex items-center gap-2 hover:opacity-90 active:scale-[0.99] transition-all shadow-md">
                    <span class="material-symbols-outlined">person_add</span>
                    Register User
                </button>
            </div>
        </form>
    </div>
    
    <!-- Main Table Container -->
    <div class="bg-white rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant">
                    <th class="px-6 py-4 font-label-caps text-label-caps text-secondary">User</th>
                    <th class="px-6 py-4 font-label-caps text-label-caps text-secondary">Phone</th>
                    <th class="px-6 py-4 font-label-caps text-label-caps text-secondary">Details</th>
                    <th class="px-6 py-4 font-label-caps text-label-caps text-secondary text-right">Actions</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">

                <!-- User Rows -->
                @foreach (var user in Model.Users)
                {
                    <tr class="hover:bg-surface-container-low/50 transition-colors group">
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 rounded-full bg-secondary-fixed flex items-center justify-center text-secondary font-bold">@user.Name.Substring(0, 1)@user.LastName.Substring(0,1)</div>
                                <div>
                                    <div class="font-semibold text-primary">@user.Name @user.LastName</div>
                                    <div class="text-sm text-outline">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-5 text-secondary">@user.Phone</td>
                        <td class="px-6 py-5 text-secondary">
                            <a asp-controller="Users" asp-action="Details" asp-route-id="@user.Id" class="p-2 text-outline hover:text-[#3B2F2F] hover:bg-surface-container-high rounded-md transition-all">
                                View
                            </a>
                        </td>
                        <td class="px-6 py-5 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id" class="p-2 text-outline hover:text-[#3B2F2F] hover:bg-surface-container-high rounded-md transition-all">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </a>
                                <form asp-action="Delete" asp-controller="Users" asp-route-id="@user.Id" method="post">
                                    <button type="submit" class="p-2 text-outline hover:text-error hover:bg-error-container/30 rounded-md transition-all">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Secondary Info Section -->
    <div class="mt-section-gap grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-6 border-l-4 border-[#6BAA75] bg-white shadow-sm rounded-r-xl">
            <h3 class="font-h3 text-h3 text-primary mb-2">Policy Compliance</h3>
            <p class="text-body-md text-secondary">All user data is managed according to the Library Digital Safety Protocol. Remember to verify ID for all Premium memberships.</p>
        </div>
        <div class="p-6 border-l-4 border-secondary bg-white shadow-sm rounded-r-xl">
            <h3 class="font-h3 text-h3 text-primary mb-2">Recent Changes</h3>
            <p class="text-body-md text-secondary">System-wide role update completed successfully on Oct 24th. 14 new registrations pending verification.</p>
        </div>
        <div class="p-6 border-l-4 border-primary bg-white shadow-sm rounded-r-xl">
            <h3 class="font-h3 text-h3 text-primary mb-2">Quick Shortcuts</h3>
            <div class="flex flex-wrap gap-2 mt-4">
                <span class="px-2 py-1 bg-surface-container text-xs font-bold rounded">CMD + N : NEW USER</span>
                <span class="px-2 py-1 bg-surface-container text-xs font-bold rounded">CMD + F : SEARCH</span>
            </div>
        </div>
    </div>
</section>

