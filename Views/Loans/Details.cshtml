@{
    ViewData["Title"] = "NexoLibro | Details of Loan";
}
@model Exercise4.ViewModels.LoanViewModel

<section class="max-w-7xl mx-auto px-8 py-section-gap">
    <!-- Header Section -->
    <div class="mb-section-gap">
        <h1 class="font-h1 text-h1 text-primary mb-2">Loan Information</h1>
        <p class="text-on-surface-variant font-body-lg">Displaying loan data</p>
    </div>
    
    <!-- DETAILS -->
    <div class="md:col-span-8 space-y-8 mt-8 md:mt-0 mb-5">
        <div class="bg-surface-container-lowest p-margin rounded-xl shadow-[0_4px_20px_-4px_rgba(59,47,47,0.08)] border border-surface-variant/30">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-10 gap-x-gutter">
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">ID</span>
                    <p class="font-body-lg text-primary">@Model.Loan.Id</p>
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">State</span>
                    <p class="font-body-lg text-primary">@Model.Loan.State</p>
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">Date Loaned</span>
                    <p class="font-body-lg text-primary">@Model.Loan.LoanDate</p>
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">Date of Return</span>
                    <p class="font-body-lg text-primary">@Model.Loan.ReturnDate</p>
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">Date Returned</span>
                    @if (@Model.Loan.ReturnedDate == null)
                    {
                        <p class="font-body-lg text-primary">No Returned</p>
                    }
                    else
                    {
                        <p class="font-body-lg text-primary">@Model.Loan.ReturnedDate</p>
                    }
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">User Email</span>
                    <p class="font-body-lg text-primary">@Model.Loan.User.Email</p>
                </div>
                <div class="space-y-1">
                    <span class="font-label-caps text-label-caps text-outline uppercase">Book Title</span>
                    <p class="font-body-lg text-primary">@Model.Loan.Book.Title</p>
                </div>
            </div>
        </div>
    </div>
</section>