@{
    ViewData["Title"] = "NexoLibro | Editing Loan";
}
@model Exercise4.ViewModels.LoanViewModel;
@using Exercise4.Enums;

<section class="max-w-7xl mx-auto px-8 py-section-gap">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div class="space-y-2">
            <h1 class="font-h1 text-h1 text-primary">User Updating</h1>
            <p class="text-body-lg text-secondary max-w-2xl">Update specific information of any user.</p>
        </div>
    </div>
    
    <!-- Updating Section -->
    <div class="bg-white rounded-xl shadow-sm border border-outline-variant p-8 mb-12">
        <form asp-action="Update" asp-controller="Loans" method="post" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-end">
            <!-- Required Fields -->
            <input type="hidden" asp-for="NewLoan.Id">
            <input type="hidden" asp-for="NewLoan.UserId">
            <input type="hidden" asp-for="NewLoan.BookId">
            
            <div class="space-y-2"> <!-- LOAN DATE -->
                <span class="text-danger d-block" asp-validation-for="NewLoan.LoanDate"></span>
                <label class="block text-xs font-bold text-secondary uppercase tracking-wider" asp-for="NewLoan.LoanDate">Loan Date</label>
                <input class="w-full px-4 py-2.5 bg-surface rounded-lg border border-outline-variant focus:border-[#6BAA75] focus:ring-1 focus:ring-[#6BAA75] transition-all outline-none" asp-for="NewLoan.LoanDate" placeholder="@DateOnly.FromDateTime(DateTime.Now)" type="date"/>
            </div>
            <div class="col-md-6"> <!-- RETURN DATE -->
                <span class="text-danger d-block" asp-validation-for="NewLoan.ReturnDate"></span>
                <label asp-for="NewLoan.ReturnDate" class="form-label">Return Date</label>
                <input type="date" asp-for="NewLoan.ReturnDate" class="form-control">
            </div>
            <div class="col-md-6"> <!-- RETURNED DATE -->
                <span class="text-danger d-block" asp-validation-for="NewLoan.ReturnedDate"></span>
                <label asp-for="NewLoan.ReturnedDate" class="form-label">Returned Date</label>
                <input type="date" asp-for="NewLoan.ReturnedDate" class="form-control">
            </div>
            <div class="col-md-6"> <!-- STATE -->
                <span asp-validation-for="NewLoan.State" class="text-danger"></span>
                <label asp-for="NewLoan.State" class="form-label">State</label>
                <select asp-for="NewLoan.State" class="form-select" asp-items="Html.GetEnumSelectList<LoanState>()"></select>
            </div>
            
            <div class="lg:col-span-4 flex justify-end mt-2">
                <button type="submit" class="bg-[#6BAA75] text-white px-8 py-3 rounded-lg font-semibold flex items-center gap-2 hover:opacity-90 active:scale-[0.99] transition-all shadow-md">
                    <span class="material-symbols-outlined">update</span>
                    Update Loan
                </button>
            </div>
        </form>
    </div>
</section>